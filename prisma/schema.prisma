generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRESQL_URL")
}

model Movie {
  id String @id @default(uuid())

  title       String
  description String?
  releaseYear Int     @map("release_year")

  raiting     Float   @default(0.0)
  isAvailable Boolean @default(false) @map("is_available")

  genre Genre @default(DRAMA)

  poster   MoviePoster? @relation(fields: [posterId], references: [id])
  posterId String?      @unique @map("poster_id")

  reviews Review[] @relation("MovieReviews")
  actors  Actor[]  @relation("MovieActors")

  createdAt DateTime @default(now()) @map("created_at")
  updateAt  DateTime @updatedAt @map("update_at")

  @@index([releaseYear])
  @@map("movies")
}

model Review {
  id String @id @default(uuid())

  text   String
  rating Decimal @default(0.0)

  movie   Movie?  @relation("MovieReviews", fields: [movieId], references: [id])
  movieId String? @map("movie_id")

  createdAt DateTime @default(now()) @map("created_at")
  updateAt  DateTime @updatedAt @map("update_at")

  @@map("reviews")
}

model Actor {
  id String @id @default(uuid())

  name   String
  movies Movie[] @relation("MovieActors")

  createdAt DateTime @default(now()) @map("created_at")
  updateAt  DateTime @updatedAt @map("update_at")

  @@map("actor")
}

model MoviePoster {
  id String @id @default(uuid())

  url String

  movie Movie?

  createdAt DateTime @default(now()) @map("created_at")
  updateAt  DateTime @updatedAt @map("update_at")

  @@map("movie_posters")
}

enum Genre {
  ACTION
  COMEDY
  DRAMA
  HORROR

  @@map("enum_genres")
}
